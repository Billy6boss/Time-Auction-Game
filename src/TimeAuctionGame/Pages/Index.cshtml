@page
@model IndexModel
@{
    ViewData["Title"] = "登入";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-4">
        <div class="card shadow">
            <div class="card-body text-center">
                <h2 class="card-title mb-4">🕐 時間拍賣</h2>
                <p class="text-muted mb-4">請輸入你的名字來加入遊戲</p>
                <form method="post">
                    <div class="mb-3">
                        <input type="text" class="form-control form-control-lg text-center"
                               name="playerName" placeholder="輸入玩家名稱"
                               maxlength="20" required autofocus />
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100">進入大廳</button>
                </form>
            </div>
        </div>
    </div>
</div>
