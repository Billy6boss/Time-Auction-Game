@page
@model TimeAuctionGame.Pages.LobbyModel
@{
    ViewData["Title"] = "大廳";
}

<div class="row">
    <div class="col-md-8">
        <h3>🏠 房間列表</h3>
        <div id="roomList" class="mt-3">
            <p class="text-muted">載入中...</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">建立新房間</h5>
                <div class="mb-3">
                    <label class="form-label">房間名稱</label>
                    <input type="text" id="roomName" class="form-control" placeholder="輸入房間名稱" maxlength="30" />
                </div>
                <div class="mb-3">
                    <label class="form-label">每人初始時間（分鐘）</label>
                    <select id="initialTime" class="form-select">
                        <option value="1">1 分鐘</option>
                        <option value="5" selected>5 分鐘</option>
                        <option value="10">10 分鐘</option>
                        <option value="15">15 分鐘</option>
                        <option value="20">20 分鐘</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">回合數</label>
                    <select id="totalRounds" class="form-select">
                        <option value="5">5 回合</option>
                        <option value="10" selected>10 回合</option>
                        <option value="15">15 回合</option>
                        <option value="20">20 回合</option>
                        <option value="25">25 回合</option>
                    </select>
                </div>
                <button id="createRoomBtn" class="btn btn-success w-100">建立房間</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/lobby.js" asp-append-version="true"></script>
}
