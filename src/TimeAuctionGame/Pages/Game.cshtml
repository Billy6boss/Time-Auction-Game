@page "{roomId}"
@model TimeAuctionGame.Pages.GameModel
@{
    ViewData["Title"] = "遊戲";
    Layout = null; // Full screen game view
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <title>時間拍賣 - 遊戲中</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/game.css" asp-append-version="true" />
</head>
<body class="game-body">
    <div class="game-container">
        <!-- Timer Display (Seven-Segment) -->
        <div class="timer-area">
            <div id="gameStatus" class="game-status">等待所有玩家準備...</div>
            <div class="seven-segment-display" id="timerDisplay">
                <div class="digit" id="digit-m1">0</div>
                <div class="digit-colon">:</div>
                <div class="digit" id="digit-s1">0</div>
                <div class="digit" id="digit-s2">0</div>
                <div class="digit-dot">.</div>
                <div class="digit digit-small" id="digit-ms">0</div>
            </div>
        </div>

        <!-- Big Button -->
        <div class="button-area">
            <button id="gameButton" class="game-button">
                <span class="button-text">按住</span>
            </button>
        </div>

        <!-- Player Info -->
        <div class="info-area">
            <div class="row g-2" id="playerInfoCards"></div>
        </div>

        <!-- Round Info -->
        <div class="round-info">
            <span>回合 <strong id="roundNum">0</strong> / <strong id="totalRounds">0</strong></span>
            <span class="ms-3">剩餘時間：<strong id="myRemainingTime">--:--</strong></span>
        </div>
    </div>

    <input type="hidden" id="roomId" value="@Model.RoomId" />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        function getPlayerInfo() {
            const cookies = document.cookie.split(';').reduce((acc, c) => {
                const [key, val] = c.trim().split('=');
                acc[key] = decodeURIComponent(val || '');
                return acc;
            }, {});
            return { id: cookies['PlayerId'] || '', name: cookies['PlayerName'] || '' };
        }
    </script>
    <script src="~/js/game.js" asp-append-version="true"></script>
</body>
</html>
